<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NexaCloud — Enterprise Platform</title>
  <!-- NUCLEI TRIGGER: no CSP, no X-Frame-Options, no HSTS meta equiv -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <script src="./app.js"></script>
	<link rel="stylesheet" href="./app.css">
</head>
<body>

  <!-- NUCLEI TRIGGER: HTML comment with fake credentials -->
  <!-- TODO: remove before prod — dev backdoor admin:NexaCloud2024!@# still active on /admin -->
  <!-- internal API staging: http://10.0.1.45:8080/api/v2/internal -->
  <!-- DB_HOST=nexacloud-prod.postgres.database.azure.com DB_PASS=Pr0d$ecret99 -->

  <div class="bg-grid"></div>

  <nav class="navbar">
    <div class="nav-inner">
      <div class="logo">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
          <rect width="28" height="28" rx="7" fill="#6C63FF"/>
          <path d="M7 14L12 9L17 14L22 9" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M7 19L12 14L17 19L22 14" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"/>
        </svg>
        <span>NexaCloud</span>
      </div>
      <div class="nav-links">
        <a href="#">Product</a>
        <a href="#">Docs</a>
        <a href="#">Pricing</a>
        <a href="/admin">Admin</a>
      </div>
    </div>
  </nav>

  <main class="hero">
    <div class="hero-content">
      <div class="badge">Now in GA — v4.2.1</div>
      <h1>Your infrastructure,<br><em>unified.</em></h1>
      <p class="subtitle">NexaCloud brings compute, storage, and observability into a single control plane. Built for platform teams.</p>

      <div class="login-card">
        <h2>Sign in to your workspace</h2>
        <p class="card-sub">Enter your credentials below</p>

        <form action="/api/auth/login" method="POST">
          <div class="field">
            <label for="email">Work email</label>
            <input type="email" id="email" name="email" placeholder="you@company.com" autocomplete="email">
          </div>
          <!-- NUCLEI TRIGGER: password field with autocomplete=on -->
          <div class="field">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" placeholder="••••••••" autocomplete="on">
          </div>
          <div class="field-row">
            <label class="checkbox-label">
              <input type="checkbox" name="remember"> Remember me
            </label>
            <a href="/api/auth/reset?redirect=https://nexacloud.io" class="forgot">Forgot password?</a>
          </div>
          <!-- NUCLEI TRIGGER: form with no CSRF token -->
          <button type="submit" class="btn-primary">Sign in</button>
        </form>

        <div class="divider"><span>or continue with</span></div>
        <div class="sso-buttons">
          <button class="btn-sso">
            <svg width="16" height="16" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            Google
          </button>
          <button class="btn-sso">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            GitHub
          </button>
        </div>
      </div>
    </div>

    <div class="hero-visual">
      <div class="terminal">
        <div class="term-bar">
          <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
          <span class="term-title">nexacloud — bash</span>
        </div>
        <div class="term-body">
          <div class="term-line"><span class="prompt">$</span> nexactl cluster list</div>
          <div class="term-line out">NAME          REGION       STATUS</div>
          <div class="term-line out">prod-us-east  us-east-1    <span class="ok">●</span> Running</div>
          <div class="term-line out">prod-eu-west  eu-west-1    <span class="ok">●</span> Running</div>
          <div class="term-line out">staging       us-west-2    <span class="warn">●</span> Degraded</div>
          <div class="term-line"><span class="prompt">$</span> nexactl secrets get db_password</div>
          <!-- NUCLEI TRIGGER: secret-looking string in page body -->
          <div class="term-line out">db_password: <span class="secret">ghp_xK9mN2pL4qR8sT1vW3yZ6aB0cD5eF7</span></div>
          <div class="term-line"><span class="prompt">$</span> <span class="cursor">_</span></div>
        </div>
      </div>
    </div>
  </main>

  <!-- NUCLEI TRIGGER: email disclosure -->
